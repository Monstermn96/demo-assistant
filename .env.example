# LM Studio
LM_STUDIO_URL=http://192.168.1.20:1234/v1
DEFAULT_MODEL=mistralai/magistral-small-2509
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
# Optional: seconds between keep-alive pings to avoid idle TTL unload (0 = disabled). e.g. 1800 = 30 min
# LM_STUDIO_KEEP_ALIVE_INTERVAL_SECONDS=0

# Memory Service
MEMORY_URL=http://localhost:3092
MEMORY_ENABLED=true
MEMORY_API_KEY=

# Auth
SERVICE_API_KEY=
SECRET_KEY=generate-a-secure-random-key
ADMIN_PASSWORD=your-admin-password

# Nexus
NEXUS_URL=http://localhost:3086
NEXUS_API_KEY=

# Cloudflare Access (optional)
CF_ACCESS_TEAM=
CF_ACCESS_AUD=

# File manager
SANDBOXED_DIRS=[]

# App
PORT=3093
DEBUG=false
